<Window x:Class="Parcore.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="300" Width="400"
        Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource WindowForeground}"
        WindowStyle="None" ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Icon="logo.ico">
    <Window.Resources>
        <Style x:Key="ChromeBtn" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource ChromeBtnForeground}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ChromeBtnHoverBackground}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ChromeBtnHoverForeground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource ChromeBtn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource CloseBtnHoverForeground}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Border BorderBrush="{DynamicResource DividerBackground}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Background="{DynamicResource WindowBackground}">
                <Grid Margin="16,0,10,0">
                    <TextBlock Text="SETTINGS" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TitlePForeground}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Style="{StaticResource CloseBtn}" Content="✕" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
            <StackPanel Grid.Row="1" Margin="20">
                <TextBlock Text="Theme" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="{DynamicResource WindowForeground}"/>
                <ComboBox x:Name="ThemeComboBox" Width="200" HorizontalAlignment="Left" Margin="0,0,0,20" SelectionChanged="ThemeComboBox_SelectionChanged">
                    <ComboBoxItem Content="Auto"/>
                    <ComboBoxItem Content="Dark"/>
                    <ComboBoxItem Content="Light"/>
                </ComboBox>
                <CheckBox x:Name="AutoStartCheckBox" Content="Run on Startup" Foreground="{DynamicResource WindowForeground}" Checked="AutoStart_Changed" Unchecked="AutoStart_Changed"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
