<Window x:Class="Parcore.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Parcore" Height="820" Width="1140"
        Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource WindowForeground}"
        WindowStyle="None"
        Icon="logo.ico"
        ResizeMode="CanResizeWithGrip"
        MinWidth="900" MinHeight="600">

    <Window.Resources>

        <Style x:Key="ChromeBtn" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource ChromeBtnForeground}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ChromeBtnHoverBackground}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ChromeBtnHoverForeground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource ChromeBtn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource CloseBtnHoverForeground}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardBase" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBaseBackground}"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="20,18"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style x:Key="CardLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource CardLabelForeground}"/>
        </Style>

        <Style x:Key="BigNumber" TargetType="TextBlock">
            <Setter Property="FontSize" Value="42"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource BigNumberForeground}"/>
            <Setter Property="LineHeight" Value="46"/>
        </Style>

        <Style x:Key="UnitLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource UnitLabelForeground}"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
            <Setter Property="Margin" Value="4,0,0,6"/>
        </Style>

        <Style x:Key="DeviceName" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource DeviceNameForeground}"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="Divider" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource DividerBackground}"/>
            <Setter Property="Margin" Value="0,10"/>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{DynamicResource ProgressBarBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource ProgressBarForeground}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="1"
                                Height="{TemplateBinding Height}">
                            <Border x:Name="PART_Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="1"
                                    HorizontalAlignment="Left"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border Background="{DynamicResource WindowBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource WindowBackground}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="16,0,10,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="P" FontSize="15" FontWeight="Black" Foreground="{DynamicResource TitlePForeground}" VerticalAlignment="Center"/>
                        <TextBlock Text="ARCORE" FontSize="15" FontWeight="Light" Foreground="{DynamicResource TitleARCOREForeground}" VerticalAlignment="Center" Margin="1,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="VersionLabel" Text="v1.0.0" FontSize="11" Foreground="{DynamicResource SubtitleForeground}"
                                   VerticalAlignment="Center" Margin="0,0,14,0" FontWeight="SemiBold"/>
                        <Button Style="{StaticResource ChromeBtn}" Content="⚙" Click="Settings_Click" Margin="0,0,10,0" ToolTip="Settings" FontSize="16"/>
                        <Button Style="{StaticResource ChromeBtn}" Content="⎯" Click="Minimize_Click"/>
                        <Button Style="{StaticResource ChromeBtn}" Content="⬡" Click="Maximize_Click" Margin="2,0"/>
                        <Button Style="{StaticResource CloseBtn}" Content="✕" Click="Exit_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer x:Name="MainContent" Grid.Row="1" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="10,0,10,10">
                <StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBase}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="CPU" Style="{StaticResource CardLabel}"/>
                                <TextBlock Grid.Row="1" x:Name="CpuName" Style="{StaticResource DeviceName}" Text="—"/>
                                <Grid Grid.Row="2" HorizontalAlignment="Left" Margin="0,14,0,10">
                                    <Canvas x:Name="CpuArcCanvas" Width="110" Height="110"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock x:Name="CpuLoadText" Text="0" Style="{StaticResource BigNumber}"/>
                                        <TextBlock Text="%" Style="{StaticResource UnitLabel}"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Grid.Row="3">
                                    <Border Style="{StaticResource Divider}"/>
                                    <ScrollViewer MaxHeight="130" VerticalScrollBarVisibility="Hidden">
                                        <StackPanel x:Name="CpuThreadList"/>
                                    </ScrollViewer>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardBase}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="MEMORY" Style="{StaticResource CardLabel}"/>
                                <TextBlock Grid.Row="1" x:Name="RamInfo" Style="{StaticResource DeviceName}" Text="—"/>
                                <Grid Grid.Row="2" HorizontalAlignment="Left" Margin="0,14,0,10">
                                    <Canvas x:Name="RamArcCanvas" Width="110" Height="110"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock x:Name="RamLoadText" Text="0" Style="{StaticResource BigNumber}"/>
                                        <TextBlock Text="%" Style="{StaticResource UnitLabel}"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Grid.Row="3">
                                    <Border Style="{StaticResource Divider}"/>
                                    <StackPanel x:Name="RamList"/>
                                </StackPanel>
                                <StackPanel Grid.Row="4" Margin="0,8,0,0">
                                    <TextBlock x:Name="RamUsageInfo" FontSize="11" Foreground="{DynamicResource SubtitleForeground}" FontWeight="SemiBold"/>
                                    <StackPanel x:Name="RamUsageList" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardBase}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="GPU" Style="{StaticResource CardLabel}"/>
                                <TextBlock Grid.Row="1" x:Name="GpuName" Style="{StaticResource DeviceName}" Text="—"/>
                                <Grid Grid.Row="2" HorizontalAlignment="Left" Margin="0,14,0,10">
                                    <Canvas x:Name="GpuArcCanvas" Width="110" Height="110"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock x:Name="GpuLoadText" Text="0" Style="{StaticResource BigNumber}"/>
                                        <TextBlock Text="%" Style="{StaticResource UnitLabel}"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Grid.Row="3">
                                    <Border Style="{StaticResource Divider}"/>
                                    <ScrollViewer MaxHeight="130" VerticalScrollBarVisibility="Hidden">
                                        <StackPanel x:Name="GpuEngineList"/>
                                    </ScrollViewer>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBase}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="CPU TEMPERATURE" Style="{StaticResource CardLabel}"/>
                                    <TextBlock Grid.Column="1" x:Name="CpuTempAvg" FontSize="11" Foreground="{DynamicResource SubtitleForeground}" FontWeight="SemiBold"/>
                                </Grid>
                                <Border Style="{StaticResource Divider}"/>
                                <ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Hidden">
                                    <StackPanel x:Name="CpuTempList"/>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardBase}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="GPU TEMPERATURE" Style="{StaticResource CardLabel}"/>
                                    <TextBlock Grid.Column="1" x:Name="GpuTempAvg" FontSize="11" Foreground="{DynamicResource SubtitleForeground}" FontWeight="SemiBold"/>
                                </Grid>
                                <Border Style="{StaticResource Divider}"/>
                                <ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Hidden">
                                    <StackPanel x:Name="GpuTempList"/>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBase}">
                            <StackPanel>
                                <TextBlock Text="STORAGE" Style="{StaticResource CardLabel}"/>
                                <Border Style="{StaticResource Divider}"/>
                                <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Hidden">
                                    <StackPanel x:Name="DriveList"/>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardBase}">
                            <StackPanel>
                                <TextBlock Text="FANS" Style="{StaticResource CardLabel}"/>
                                <Border Style="{StaticResource Divider}"/>
                                <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Hidden">
                                    <StackPanel x:Name="FanList"/>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardBase}">
                            <StackPanel>
                                <TextBlock Text="NETWORK" Style="{StaticResource CardLabel}"/>
                                <Border Style="{StaticResource Divider}"/>
                                <StackPanel x:Name="NetList"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <Border x:Name="LoadingOverlay" Grid.Row="1" Background="{DynamicResource LoadingOverlayBackground}" Visibility="Visible">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="LoadingText" Text="Initializing..." Foreground="{DynamicResource LoadingTextForeground}" FontSize="14" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                    <ProgressBar IsIndeterminate="True" Width="150" Height="2" Margin="0,16,0,0" Foreground="{DynamicResource ProgressBarForeground}" Background="{DynamicResource ProgressBarBackground}" BorderThickness="0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
